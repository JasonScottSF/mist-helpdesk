# Copy to .env and fill in values
SECRET_KEY=change-me-to-something-random
PORT=5004

# Regional Mist cloud base (default is global)
# Options: https://api.mist.com  https://api.eu.mist.com  https://api.gc1.mist.com
MIST_BASE=https://api.mist.com

# Session lifetime in seconds (default 8 hours)
SESSION_TTL=28800
